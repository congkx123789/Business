{
  "name": "novels-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Multi-platform novel reading application monorepo",
  "scripts": {
    "dev:gateway": "pnpm --filter 1-gateway start:dev",
    "dev:web": "pnpm --filter 3-web dev",
    "dev:desktop": "pnpm --filter 4-desktop dev",
    "dev:users": "pnpm --filter users-service start:dev",
    "dev:stories": "pnpm --filter stories-service start:dev",
    "dev:comments": "pnpm --filter comments-service start:dev",
    "dev:search": "pnpm --filter search-service start:dev",
    "dev:ai": "pnpm --filter ai-service start:dev",
    "dev:notification": "pnpm --filter notification-service start:dev",
    "dev:websocket": "pnpm --filter websocket-service start:dev",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "infra:check": "docker --version && docker compose version",
    "setup:docker": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-docker.ps1",
    "start:all": "powershell -ExecutionPolicy Bypass -File ./scripts/start-all.ps1",
    "start:all:single": "powershell -ExecutionPolicy Bypass -File ./scripts/start-all-single.ps1",
    "check:services": "powershell -ExecutionPolicy Bypass -File ./scripts/check-services.ps1",
    "kill:services": "powershell -ExecutionPolicy Bypass -File ./scripts/kill-services.ps1",
    "restart:all": "powershell -ExecutionPolicy Bypass -File ./scripts/restart-and-monitor.ps1",
    "restart:all:skip-kill": "powershell -ExecutionPolicy Bypass -File ./scripts/restart-and-monitor.ps1 -SkipKill",
    "restart:all:all-errors": "powershell -ExecutionPolicy Bypass -File ./scripts/restart-and-monitor.ps1 -ShowAllErrors",
    "install:all": "pnpm install",
    "postinstall": "powershell -ExecutionPolicy Bypass -File ./scripts/apply-bull-patch.ps1",
    "check:ports": "powershell -ExecutionPolicy Bypass -File ./scripts/check-ports.ps1",
    "check:ports:ts": "bun run scripts/check-ports.ts",
    "fix:ports": "powershell -ExecutionPolicy Bypass -File ./scripts/fix-ports.ps1",
    "fix:ports:ts": "bun run scripts/fix-ports.ts",
    "lint": "turbo lint",
    "format": "turbo format",
    "build": "turbo build",
    "test": "turbo test"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "turbo": "^2.0.0"
  },
  "packageManager": "pnpm@8.15.5"
}

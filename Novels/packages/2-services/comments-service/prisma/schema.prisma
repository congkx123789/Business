generator client {
  provider = "prisma-client-js"
  output   = "../../../../node_modules/@prisma/comments-service-client"
}

datasource db {
  provider = "postgresql"
  url      = env("COMMENTS_SERVICE_DATABASE_URL")
}

model ParagraphComment {
  id             String                  @id @default(cuid())
  storyId        String
  chapterId      String
  userId         String
  paragraphIndex Int
  paragraphText  String
  content        String
  reactionType   String?
  likeCount      Int                     @default(0)
  replyCount     Int                     @default(0)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  likes          ParagraphCommentLike[]
  replies        ParagraphCommentReply[]

  @@index([storyId])
  @@index([chapterId, paragraphIndex])
}

model ParagraphCommentLike {
  id        String            @id @default(cuid())
  commentId String
  userId    String
  isAuthor  Boolean           @default(false)
  createdAt DateTime          @default(now())

  comment   ParagraphComment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}

model ParagraphCommentReply {
  id            String           @id @default(cuid())
  commentId     String
  userId        String
  content       String
  isAuthorReply Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  comment       ParagraphComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([commentId])
}

model ChapterComment {
  id        String            @id @default(cuid())
  storyId   String
  chapterId String
  userId    String
  content   String
  parentId  String?
  upvotes   Int               @default(0)
  downvotes Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  parent    ChapterComment?   @relation("ChapterCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   ChapterComment[]  @relation("ChapterCommentReplies")
  votes     ChapterCommentVote[]

  @@index([storyId])
  @@index([chapterId])
  @@index([parentId])
}

model ChapterCommentVote {
  id        String          @id @default(cuid())
  commentId String
  userId    String
  value     Int             // -1 or 1
  createdAt DateTime        @default(now())

  comment   ChapterComment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}

model Review {
  id                   String              @id @default(cuid())
  storyId              String
  userId               String
  title                String?
  content              String
  plotRating           Int?
  characterRating      Int?
  writingStyleRating   Int?
  overallRating        Int
  helpfulCount         Int                 @default(0)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  helpfulVotes         ReviewHelpfulVote[]

  @@index([storyId])
  @@unique([storyId, userId])
}

model ReviewHelpfulVote {
  id        String  @id @default(cuid())
  reviewId  String
  userId    String
  createdAt DateTime @default(now())

  review    Review  @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
}

model ForumThread {
  id          String      @id @default(cuid())
  storyId     String
  userId      String
  title       String
  content     String
  category    String
  isPinned    Boolean     @default(false)
  isLocked    Boolean     @default(false)
  postCount   Int         @default(0)
  lastPostAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  posts       ForumPost[]

  @@index([storyId])
  @@index([category])
}

model ForumPost {
  id           String      @id @default(cuid())
  threadId     String
  userId       String
  content      String
  parentPostId String?
  likeCount    Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  thread       ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  parent       ForumPost?  @relation("ForumPostReplies", fields: [parentPostId], references: [id], onDelete: Cascade)
  replies      ForumPost[] @relation("ForumPostReplies")

  @@index([threadId])
  @@index([parentPostId])
}

model Poll {
  id          String       @id @default(cuid())
  storyId     String?
  createdBy   String
  title       String
  description String?
  endsAt      DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  options     PollOption[]
  votes       PollVote[]
}

model PollOption {
  id        String     @id @default(cuid())
  pollId    String
  label     String
  order     Int        @default(0)
  voteCount Int        @default(0)

  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes     PollVote[]

  @@index([pollId])
}

model PollVote {
  id        String     @id @default(cuid())
  pollId    String
  optionId  String
  userId    String
  createdAt DateTime   @default(now())

  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([optionId])
}

model Quiz {
  id            String           @id @default(cuid())
  storyId       String?
  createdBy     String
  title         String
  description   String?
  timeLimit     Int?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  questions     QuizQuestion[]
  submissions   QuizSubmission[]
}

model QuizQuestion {
  id          String        @id @default(cuid())
  quizId      String
  prompt      String
  explanation String?

  quiz        Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options     QuizOption[]
  answers     QuizSubmissionAnswer[]
}

model QuizOption {
  id          String       @id @default(cuid())
  questionId  String
  text        String
  isCorrect   Boolean      @default(false)

  question    QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers     QuizSubmissionAnswer[]
}

model QuizSubmission {
  id             String                 @id @default(cuid())
  quizId         String
  userId         String
  score          Int
  totalQuestions Int
  timeSpent      Int?
  createdAt      DateTime               @default(now())

  quiz           Quiz                   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers        QuizSubmissionAnswer[]

  @@unique([quizId, userId])
}

model QuizSubmissionAnswer {
  id            String          @id @default(cuid())
  submissionId  String
  questionId    String
  optionId      String
  isCorrect     Boolean

  submission    QuizSubmission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question      QuizQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option        QuizOption      @relation(fields: [optionId], references: [id], onDelete: Cascade)
}

model Rating {
  id        String   @id @default(cuid())
  storyId   String
  userId    String
  rating    Int
  review    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storyId, userId])
  @@index([storyId])
}



// Prisma schema for social-service
// This service manages Posts, Groups, Follows, Feeds

generator client {
  provider = "prisma-client-js"
  output   = "../../../../../node_modules/@prisma/social-service-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id        Int      @id @default(autoincrement())
  userId    Int
  content   String   @db.Text
  storyId   Int?
  groupId   Int?
  likeCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  story     Story?   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  group     Group?   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  likes     PostLike[]

  @@index([userId])
  @@index([storyId])
  @@index([groupId])
  @@index([createdAt])
}

model Group {
  id          Int      @id @default(autoincrement())
  ownerId     Int
  name        String
  description String?  @db.Text
  type        String   @default("general") // 'general' | 'book-club'
  storyId     Int?
  memberCount Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  owner       User?             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  story       Story?            @relation(fields: [storyId], references: [id], onDelete: Cascade)
  members     GroupMember[]
  posts       Post[]
  schedules   ReadingSchedule[]

  @@index([ownerId])
  @@index([storyId])
}

model GroupMember {
  id        Int      @id @default(autoincrement())
  groupId   Int
  userId    Int
  role      String   @default("member") // "owner", "admin", "member"
  joinedAt  DateTime @default(now())

  // Relations
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@index([groupId])
}

model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int
  followingId Int
  createdAt   DateTime @default(now())

  // Relations
  follower    User?    @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  following   User?    @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model PostLike {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    Int
  createdAt DateTime @default(now())

  // Relations
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId])
  @@index([postId])
}

// External references (these would be in users-service and stories-service)
model User {
  id Int @id @default(autoincrement())
  
  // Relations (for Prisma schema validation only - actual data in users-service)
  posts                 Post[]
  groups                Group[]
  groupMembers          GroupMember[]
  followers             Follow[]             @relation("Followers")
  following             Follow[]             @relation("Following")
  postLikes             PostLike[]
  readingChallenges     ReadingChallenge[]
  challengeParticipants ChallengeParticipant[]
  activityTracking      ActivityTracking[]
  readingGoals          ReadingGoal[]
}

model Story {
  id Int @id @default(autoincrement())
  
  // Relations (for Prisma schema validation only - actual data in stories-service)
  posts Post[]
  groups Group[]
  schedules ReadingSchedule[]
  activityTracking ActivityTracking[]
}

model ReadingSchedule {
  id             Int      @id @default(autoincrement())
  groupId        Int
  storyId        Int
  chapterNumber  Int
  deadline       DateTime
  discussionDate DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([storyId])
}

model ReadingChallenge {
  id            Int       @id @default(autoincrement())
  creatorId     Int
  name          String
  description   String?   @db.Text
  challengeType String    @default("personal") // 'personal' | 'community'
  goal          Int
  goalType      String    // 'books' | 'chapters' | 'reading-time' | 'pages'
  timeRange     String    // 'daily' | 'weekly' | 'monthly' | 'yearly' | 'custom'
  startDate     DateTime
  endDate       DateTime
  progress      Int       @default(0)
  status        String    @default("active")
  isPublic      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  creator       User?                   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  participants  ChallengeParticipant[]

  @@index([creatorId])
  @@index([challengeType])
  @@index([status])
}

model ChallengeParticipant {
  id          Int              @id @default(autoincrement())
  challengeId Int
  userId      Int
  progress    Int              @default(0)
  joinedAt    DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  metadata    Json?

  challenge   ReadingChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User?            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([userId])
}

model ActivityTracking {
  id           Int      @id @default(autoincrement())
  userId       Int
  activityType String
  storyId      Int?
  chapterId    Int?
  metadata     Json?
  timestamp    DateTime @default(now())
  createdAt    DateTime @default(now())

  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  story  Story? @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
}

model ReadingGoal {
  id        Int      @id @default(autoincrement())
  userId    Int
  goalType  String   // 'books' | 'chapters' | 'reading-time' | 'pages'
  target    Int
  current   Int      @default(0)
  timeRange String   // 'daily' | 'weekly' | 'monthly' | 'yearly' | 'custom'
  startDate DateTime
  endDate   DateTime
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@unique([userId, goalType, timeRange])
}





# Frontend Environment Configuration Template
# Copy this file to frontend/.env and update with your actual values

# API Configuration
VITE_API_BASE_URL=http://localhost:8080/api

# Environment
VITE_ENV=development

# Feature Flags
VITE_ENABLE_OAUTH2=true
VITE_ENABLE_ANALYTICS=true

# External Services (if needed)
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# VITE_STRIPE_PUBLIC_KEY=your_stripe_public_key

# Image CDN Configuration
VITE_CDN_ENABLED=false
VITE_CDN_BASE_URL=https://your-cdn-domain.cloudfront.net


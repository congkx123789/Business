{
  "name": "selfcar-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ui": "vitest --coverage --ui",
    "test:watch": "vitest --watch",
    "test:integration": "vitest run src/pages/__tests__/",
    "test:unit": "vitest run --exclude '**/__tests__/**' --exclude '**/e2e/**'",
    "test:accessibility": "vitest run src/test/accessibility.test.jsx",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:run && npm run test:e2e",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lighthouse": "lhci autorun",
    "analyze": "vite build --config vite.bundle.analyzer.js"
  },
  "dependencies": {
    "@sentry/react": "^10.23.0",
    "@sentry/replay": "^7.116.0",
    "@tanstack/react-query": "^5.17.0",
    "axios": "^1.6.2",
    "date-fns": "^3.0.6",
    "framer-motion": "^11.0.0",
    "i18next": "^23.7.6",
    "i18next-browser-languagedetector": "^7.2.0",
    "lucide-react": "^0.303.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.2",
    "react-i18next": "^14.0.0",
    "react-icons": "^5.0.1",
    "react-router-dom": "^6.21.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.0",
    "@chromatic-com/storybook": "^4.1.2",
    "@hookform/resolvers": "^3.3.4",
    "@playwright/test": "^1.56.1",
    "@storybook/addon-a11y": "^8.6.14",
    "@storybook/addon-docs": "^10.0.2",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-onboarding": "^10.0.2",
    "@storybook/addon-vitest": "^10.0.2",
    "@storybook/react-vite": "^8.6.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/browser-playwright": "4.0.6",
    "@vitest/coverage-v8": "4.0.6",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "eslint-plugin-storybook": "^10.0.2",
    "jest-axe": "^10.0.0",
    "jsdom": "^27.1.0",
    "msw": "^2.4.5",
    "playwright": "^1.56.1",
    "postcss": "^8.4.32",
    "prop-types": "^15.8.1",
    "react-hot-toast": "^2.6.0",
    "storybook": "^10.0.2",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.8",
    "vitest": "^4.0.6"
  }
}

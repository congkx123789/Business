{
  "annotations": {"list": []},
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "gauge",
      "title": "Payments SLI vs SLO",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "targets": [
        {"expr": "sli:payments_success:ratio", "refId": "A"}
      ],
      "pluginVersion": "9",
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {"color": "red", "value": null},
            {"color": "green", "value": 0.9999}
          ]
        },
        "orientation": "auto"
      },
      "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 5}, "overrides": []}
    },
    {
      "type": "gauge",
      "title": "API Availability SLI vs SLO",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "targets": [
        {"expr": "sli:api_availability:ratio", "refId": "A"}
      ],
      "pluginVersion": "9",
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "thresholds": {"mode": "absolute", "steps": [{"color": "red"}, {"color": "green", "value": 0.999}]}
      },
      "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 4}, "overrides": []}
    },
    {
      "type": "gauge",
      "title": "Inventory Consistency SLI vs SLO",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "targets": [
        {"expr": "sli:inventory_consistency:ratio", "refId": "A"}
      ],
      "pluginVersion": "9",
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "thresholds": {"mode": "absolute", "steps": [{"color": "red"}, {"color": "green", "value": 0.99999}]}
      },
      "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 5}, "overrides": []}
    },
    {
      "type": "timeseries",
      "title": "Burn Rates (Payments, API, Inventory)",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 8},
      "targets": [
        {"expr": "burn:payments", "legendFormat": "payments", "refId": "A"},
        {"expr": "burn:api", "legendFormat": "api", "refId": "B"},
        {"expr": "burn:inventory", "legendFormat": "inventory", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "type": "stat",
      "title": "Search P99 Latency (s)",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 18},
      "targets": [
        {"expr": "sli:search_p99_latency:seconds", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 3}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "type": "stat",
      "title": "Payments Budget Remaining (30d est)",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 18},
      "targets": [
        {"expr": "(slo:target:payments_success * 1) - sum_over_time((1 - sli:payments_success:ratio)[30d])", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 4}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    },
    {
      "type": "stat",
      "title": "API Budget Remaining (30d est)",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 18},
      "targets": [
        {"expr": "(slo:target:api_availability * 1) - sum_over_time((1 - sli:api_availability:ratio)[30d])", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 4}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 37,
  "style": "dark",
  "tags": ["slo", "error-budgets"],
  "templating": {"list": []},
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "SLOs & Error Budgets",
  "uid": "slo-error-budgets",
  "version": 1
}



{
  "manifest_version": 3,
  "name": "Automation Bridge",
  "version": "0.1.0",
  "description": "Bridges a Chrome extension to a secure native host for automation.",
  "permissions": [
    "nativeMessaging",
    "storage"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Automation",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}

